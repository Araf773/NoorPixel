# ---------------------------------------------------------------------------
# NoorPixel environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# On Vercel, set these in Project Settings -> Environment Variables instead.
# ---------------------------------------------------------------------------

# --- Cloudinary (image storage + CDN) -------------------------------------
# From your Cloudinary dashboard. cloud_name is public; API key/secret are NOT.
# The secret must stay server-side only (no VITE_ prefix) — it signs uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Neon Postgres (wallpaper metadata) -----------------------------------
# Connection string from the Neon console (use the pooled connection string).
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# --- Admin auth ------------------------------------------------------------
# A long random secret that gates uploads/deletes. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=
